# StrategyPMO Environment Variables
# Copy this file to .env and fill in values
# Lines marked [REQUIRED] must be set. Others have sensible defaults.

# ──────────────────────────────────────────────
# DATABASE [REQUIRED]
# ──────────────────────────────────────────────
DATABASE_URL=postgres://spmo:your_password@localhost:5432/strategypmo
DB_PASSWORD=your_secure_password_here

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com/strategy-pmo
ALLOWED_ORIGINS=https://your-domain.com
LOG_LEVEL=info

# ──────────────────────────────────────────────
# AUTHENTICATION [REQUIRED — pick one provider]
# ──────────────────────────────────────────────
# Option A: Replit OIDC (default for Replit deployments)
ISSUER_URL=https://replit.com/oidc
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Option B: Azure AD
# ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
# OIDC_CLIENT_ID=your-azure-app-client-id
# OIDC_CLIENT_SECRET=your-azure-app-client-secret

# Option C: Keycloak
# ISSUER_URL=https://keycloak.your-domain.com/realms/your-realm
# OIDC_CLIENT_ID=strategypmo
# OIDC_CLIENT_SECRET=your-keycloak-secret

# Session security
SESSION_SECRET=generate-a-random-64-char-string-here
COOKIE_SAMESITE=lax

# First admin user — this email gets admin role on first login
INITIAL_ADMIN_EMAIL=admin@your-domain.com

# ──────────────────────────────────────────────
# AI FEATURES (optional — app works without it)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# EMAIL (optional — configure ONE transport)
# ──────────────────────────────────────────────
# Cascade: Resend → SendGrid → SMTP (first configured wins)

# Resend (recommended — simplest)
RESEND_API_KEY=re_...

# SendGrid
# SENDGRID_API_KEY=SG...

# SMTP (any provider: Office 365, Gmail, etc.)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=noreply@your-domain.com
# SMTP_PASS=your-smtp-password

EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=StrategyPMO

# ──────────────────────────────────────────────
# FILE STORAGE (optional — for evidence uploads)
# ──────────────────────────────────────────────
# Currently uses Replit Object Storage.
# For S3-compatible storage, set:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET=strategypmo-uploads
# PRIVATE_OBJECT_DIR=uploads/private
# PUBLIC_OBJECT_SEARCH_PATHS=uploads/public

# ──────────────────────────────────────────────
# DOCKER COMPOSE OVERRIDES
# ──────────────────────────────────────────────
# APP_PORT=3000       # Host port for the app
# DB_PORT=5432        # Host port for PostgreSQL
