# StrategyPMO Environment Variables
# Copy this file to .env and fill in values

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/strategypmo
PORT=3000

# OIDC Authentication (defaults to Replit if not set)
# For Azure AD: set ISSUER_URL to https://login.microsoftonline.com/{tenant}/v2.0
ISSUER_URL=https://replit.com/oidc
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Legacy Replit auth (used as fallback for OIDC_CLIENT_ID)
# REPL_ID=

# CORS - comma-separated allowed origins (defaults to *.repl.co, *.replit.dev)
# ALLOWED_ORIGINS=https://your-domain.gov

# Application URL (used for OIDC redirect URI if set)
# APP_URL=https://your-domain.gov

# Initial admin - email of the first admin user (if not set, first user gets admin)
# INITIAL_ADMIN_EMAIL=admin@your-domain.gov

# Cookie SameSite policy: strict, lax, or none (default: lax)
# COOKIE_SAMESITE=lax

# AI Integration
# ANTHROPIC_API_KEY=sk-ant-...
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# Object Storage
# PRIVATE_OBJECT_DIR=/data/objects
# PUBLIC_OBJECT_SEARCH_PATHS=/data/public

# Application
BASE_PATH=/strategy-pmo/
LOG_LEVEL=info
# FORCE_RESEED=true
