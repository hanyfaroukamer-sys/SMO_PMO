{
  "expo": {
    "name": "StrategyPMO",
    "slug": "strategy-pmo-mobile",
    "version": "1.0.0",
    "scheme": "strategypmo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.strategypmo.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.strategypmo.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
