{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.cjs",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'src/__tests__/engines/**' --exclude 'src/__tests__/api/**' --exclude 'src/__tests__/workflows/**' --exclude 'src/__tests__/security/injection.test.ts'",
    "test:integration": "vitest run src/__tests__/engines src/__tests__/api src/__tests__/workflows src/__tests__/security/injection.test.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts --reporter=verbose",
    "test:e2e:wiring": "vitest run --config vitest.config.e2e.ts src/__tests__/e2e/frontend-wiring.test.ts --reporter=verbose",
    "test:all": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/nodemailer": "^7.0.11",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5",
    "express-rate-limit": "^7.5.0",
    "fast-xml-parser": "^5.5.8",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "officeparser": "^6.0.4",
    "openid-client": "^6.8.2",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "pptxgenjs": "^4.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "tsx": "catalog:",
    "vitest": "^4.1.0"
  }
}
