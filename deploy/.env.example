# StrategyPMO — Production Environment Configuration
# Copy to .env and fill in all required (*) values before starting.

# ─── Database ────────────────────────────────────────────────────────────────
# * Change this to a strong password
DB_PASSWORD=changeme_in_production

# Only set this if using an external database (not docker-compose db service)
# DATABASE_URL=postgresql://user:pass@your-db-host:5432/strategypmo

# ─── Authentication (OIDC) ──────────────────────────────────────────────────
# * Configure your identity provider
# Azure AD:    https://login.microsoftonline.com/{tenant-id}/v2.0
# Keycloak:    https://keycloak.example.com/realms/{realm}
# Okta:        https://{org}.okta.com/oauth2/default
ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ─── Security ───────────────────────────────────────────────────────────────
# * Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://pmo.example.gov.sa

# * Public URL of the application (used for OIDC redirects)
APP_URL=https://pmo.example.gov.sa

# Cookie SameSite policy: strict, lax, or none
COOKIE_SAMESITE=lax

# ─── Email Notifications (optional — pick ONE method) ──────────────────────
# Enables: @mention alerts, task reminders, approval notifications.
# Priority: Resend > SendGrid > SMTP. First configured wins.
#
# Method 1: Resend (easiest — https://resend.com, free 100 emails/day)
# RESEND_API_KEY=re_xxxxx
#
# Method 2: SendGrid (https://sendgrid.com, free 100 emails/day)
# SENDGRID_API_KEY=SG.xxxxx
#
# Method 3: Corporate SMTP (Exchange, Google Workspace, etc.)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=pmo-noreply@example.gov.sa
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
#
# Sender address (used by all methods):
# EMAIL_FROM=noreply@example.gov.sa
# EMAIL_FROM_NAME=StrategyPMO

# ─── AI Features (optional) ────────────────────────────────────────────────
# Anthropic API key enables AI-powered project analysis
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Application ────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
BASE_PATH=/strategy-pmo/

# Set to 'true' to force reload seed data on next restart (one-time)
# FORCE_RESEED=

# ─── Ports (Nginx) ─────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
